DB_HOST=localhost
DB_PORT=5432
DB_NAME=retail_assistant
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/retail_assistant
VELORA_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velora_retail

NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h

GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-3-flash-preview
LANGCHAIN_API_KEY=replace-me
LANGCHAIN_PROJECT=copilot project
LANGCHAIN_TRACING_V2=true
AGENT_MAX_TOOL_CALLS=4
AGENT_MAX_PLANNING_ITERATIONS=2

LLM_PROVIDER=openai_compat
LLM_MODEL=Qwen/Qwen3-32B-TEE
LLM_BASE_URL=https://llm.chutes.ai/v1/chat/completions
LLM_API_KEY=replace-me

EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_BASE_URL=https://chutes-qwen-qwen3-embedding-0-6b.chutes.ai/v1
EMBEDDING_API_KEY=replace-me

SEARCH_PROVIDER=tavily
TAVILY_API_KEY=replace-me
SEARCH_TIMEOUT_MS=8000
SEARCH_MAX_RESULTS=5

VELORA_API_URL=http://localhost:4001
VELORA_API_KEY=velora-demo-key-2024
