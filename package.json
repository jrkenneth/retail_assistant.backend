{
  "name": "@velora/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "npm run typecheck",
    "start": "tsx src/index.ts",
    "db:migrate": "knex migrate:latest --knexfile knexfile.cjs",
    "db:rollback": "knex migrate:rollback --knexfile knexfile.cjs",
    "db:make": "knex migrate:make --knexfile knexfile.cjs",
    "db:seed": "knex seed:run --knexfile knexfile.cjs",
    "lint": "echo \"backend lint not configured yet\"",
    "test": "npm run typecheck"
  },
  "dependencies": {
    "@langchain/core": "^1.1.28",
    "@langchain/google-genai": "^2.1.20",
    "@langchain/openai": "^1.2.10",
    "axios": "^1.13.6",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "langchain": "^1.2.27",
    "pg": "^8.18.0",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.37.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "knex-types": "^0.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
